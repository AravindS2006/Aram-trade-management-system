{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dev Dependencies",
      "type": "shell",
      "command": "uv",
      "args": [
        "sync",
        "--group",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backtest_system"
      }
    },
    {
      "label": "Lint (Ruff)",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "ruff",
        "check",
        "."
      ],
      "options": {
        "cwd": "${workspaceFolder}/backtest_system"
      },
      "group": "test"
    },
    {
      "label": "Type Check (Mypy)",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "mypy",
        "core",
        "strategies",
        "app.py",
        "main.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backtest_system"
      },
      "group": "test"
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "pytest"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backtest_system"
      },
      "group": "test"
    },
    {
      "label": "Run Streamlit App",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "streamlit",
        "run",
        "app.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backtest_system"
      },
      "group": "build",
      "isBackground": true
    }
  ]
}