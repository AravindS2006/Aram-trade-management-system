# Aram-TMS Environment Configuration
# Copy to .env and fill in your credentials
# NEVER commit .env to git

# --- DhanHQ Sandbox (Forward Testing) ---
DHAN_SANDBOX_CLIENT_ID=your_sandbox_client_id_here
DHAN_SANDBOX_ACCESS_TOKEN=your_sandbox_access_token_here

# --- DhanHQ Live (Production — use with extreme caution) ---
DHAN_CLIENT_ID=your_live_client_id_here
DHAN_ACCESS_TOKEN=your_live_access_token_here

# --- Data Paths ---
KAGGLE_DATA_PATH=C:\Users\aravi\Documents\GitHub\Aram-trade-management-system\data\raw\csv\
PROCESSED_DATA_PATH=C:\Users\aravi\Documents\GitHub\Aram-trade-management-system\data\processed\
RESULTS_PATH=C:\Users\aravi\Documents\GitHub\Aram-trade-management-system\data\results\

# --- Notifications (Optional) ---
ALERT_EMAIL=your_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# --- System ---
LOG_LEVEL=INFO
TRADING_MODE=backtest
