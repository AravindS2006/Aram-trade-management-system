# Core runtime
ENV=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata

# Data and caching
DATA_DIR=data
USE_DATA_CACHE=true

# Backtest defaults
DEFAULT_SYMBOL=RELIANCE.NS
DEFAULT_INTERVAL=1m
DEFAULT_INITIAL_CAPITAL=100000
DEFAULT_RISK_PER_TRADE_PCT=0.01
DEFAULT_SL_PCT=0.01
DEFAULT_TP_PCT=0.02
DEFAULT_TSL_PCT=0.005
DEFAULT_SLIPPAGE=0.0005

# Execution safety toggles for future live mode
LIVE_TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true
MAX_DAILY_LOSS_PCT=2.0
MAX_OPEN_POSITIONS=1
KILL_SWITCH=false

# LLM optimizer settings (Gemini)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-pro
# Leave blank to use Gemini default endpoint assembled from model.
LLM_OPT_ENDPOINT=
# Preferred key variable for Gemini
GEMINI_API_KEY=
# Optional backward-compatible key name
LLM_API_KEY=
